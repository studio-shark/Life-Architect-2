<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:name=".LifeArchitectApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LifeArchitect2">

        <!-- Google AdMob App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-7210557644472819~2228592252"/>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.LifeArchitect2"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ══════════════════════════════════════════════════════════════════
             WIDGET COMPONENTS
             ══════════════════════════════════════════════════════════════════ -->

        <!--
            TaskWidgetProvider — the BroadcastReceiver that orchestrates the
            task list home screen widget.

            Uses the modern RemoteViews.RemoteCollectionItems API (API 31+)
            instead of the deprecated RemoteViewsService pattern. The provider
            builds and pushes the full RemoteViews — including the collection —
            directly via AppWidgetManager.updateAppWidget(), so no separate
            RemoteViewsService is needed.

            ACTION_WIDGET_REFRESH is sent by MainViewModel (and
            WidgetOverlayService) after any task mutation, triggering a full
            widget rebuild on Dispatchers.IO inside the provider.

            ACTION_COMPLETE_TASK is sent when the user taps a task row on the
            widget; the provider marks it done in Room and immediately rebuilds
            the widget.
        -->
        <receiver
            android:name=".widget.TaskWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.mirchevsky.lifearchitect2.WIDGET_REFRESH" />
                <action android:name="com.mirchevsky.lifearchitect2.COMPLETE_TASK" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/task_widget_info" />
        </receiver>

        <!--
            NOTE: TaskWidgetService (RemoteViewsService) has been removed.
            The widget now uses RemoteViews.RemoteCollectionItems, which does
            not require a bound service. The BIND_REMOTEVIEWS permission is
            no longer needed.
        -->

        <!--
            WidgetOverlayService — ForegroundService that draws the slide-up
            Compose input panel via WindowManager + TYPE_APPLICATION_OVERLAY.

            Started by the widget's +, mic, and calendar PendingIntents.
            Requires SYSTEM_ALERT_WINDOW permission (user grants once via
            Settings). Uses foregroundServiceType="specialUse" as required
            by Android 14+ for overlay-drawing foreground services.
        -->
        <service
            android:name=".widget.WidgetOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="overlay_input" />
        </service>

        <!--
            The three old dialog activities below are superseded by
            WidgetOverlayService but are kept here so the build does not break
            if any existing code still references them. They can be removed
            once you have verified the overlay service works end-to-end.
        -->
        <activity
            android:name=".widget.WidgetAddTaskActivity"
            android:exported="false"
            android:theme="@style/Theme.LifeArchitect2.WidgetDialog"
            android:excludeFromRecents="true"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <activity
            android:name=".widget.WidgetAddEventActivity"
            android:exported="false"
            android:theme="@style/Theme.LifeArchitect2.WidgetDialog"
            android:excludeFromRecents="true"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <activity
            android:name=".widget.WidgetVoiceActivity"
            android:exported="false"
            android:theme="@style/Theme.LifeArchitect2.WidgetDialog"
            android:excludeFromRecents="true" />

        <!--
            MicPermissionActivity — transparent trampoline Activity that
            requests RECORD_AUDIO on behalf of WidgetOverlayService.
            Services cannot call requestPermissions() directly, so this
            zero-UI Activity is launched on the first mic tap.
        -->
        <activity
            android:name=".widget.MicPermissionActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleInstance" />

        <!--
            CalendarPermissionActivity — transparent trampoline Activity that
            requests READ_CALENDAR + WRITE_CALENDAR on behalf of
            WidgetOverlayService. Services cannot call requestPermissions()
            directly, so this zero-UI Activity is launched on the first
            calendar event creation attempt when permissions have not yet
            been granted.
        -->
        <activity
            android:name=".widget.CalendarPermissionActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleInstance" />

        <!--
            OverlayPermissionDialogActivity — transparent trampoline Activity
            that shows a friendly in-app dialog explaining the overlay permission
            before deep-linking the user to the app's own toggle in Settings.
            Launched by WidgetOverlayService when canDrawOverlays() is false.
        -->
        <activity
            android:name=".widget.OverlayPermissionDialogActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleInstance" />

    </application>

</manifest>
