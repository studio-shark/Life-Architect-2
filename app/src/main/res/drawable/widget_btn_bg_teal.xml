<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_btn_bg_teal.xml
    ─────────────────────────────────────────────────────────────────────────
    Rounded-square background for the mic button on the widget header.
    Matches the app's BrandGreen (#10B981) used for the mic FilledIconButton
    in AddTaskItem.kt (MaterialTheme.colorScheme.primary = BrandGreen).

    Corner radius of 10dp matches the app's RoundedCornerShape(12.dp) at
    widget scale (slightly tighter due to smaller button size).

    Place at: app/src/main/res/drawable/widget_btn_bg_teal.xml
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#10B981" />
    <corners android:radius="10dp" />
</shape>
