<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_task_item_urgent.xml
    ─────────────────────────────────────────────────────────────────────────
    Task row layout for URGENT tasks.

    Structurally identical to widget_task_item.xml (normal) and
    widget_task_item_pinned.xml. Using a separate layout file forces the
    launcher's RemoteCollectionItems view recycler to maintain a distinct
    view cache for urgent rows.

    Place at: app/src/main/res/layout/widget_task_item_urgent.xml
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_item_bg"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:layout_marginBottom="6dp"
    android:minHeight="48dp">

    <ImageView
        android:id="@+id/widget_item_dot"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/widget_checkbox_unchecked"
        android:contentDescription="Complete task" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_primary"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:id="@+id/widget_item_date_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_item_due"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:maxLines="1" />

            <ImageView
                android:id="@+id/widget_item_calendar"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="3dp"
                android:src="@drawable/widget_ic_calendar"
                android:contentDescription="Calendar event"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <ImageView
        android:id="@+id/widget_item_flag"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/widget_ic_flag"
        android:contentDescription="Toggle urgent"
        android:visibility="visible" />

    <ImageView
        android:id="@+id/widget_item_pin"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/widget_ic_pin"
        android:contentDescription="Toggle pin"
        android:visibility="visible" />

</LinearLayout>
