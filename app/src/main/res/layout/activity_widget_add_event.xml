<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_widget_add_event.xml
    ─────────────────────────────────────────────────────────────────────────
    Layout for the "Add Calendar Event" dialog launched from the widget
    calendar button. Appears as a floating dialog over the home screen.

    Place at: app/src/main/res/layout/activity_widget_add_event.xml
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1C1C2E"
    android:padding="24dp">

    <!-- ── Dialog title ───────────────────────────────────────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New Calendar Event"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="16dp" />

    <!-- ── Event title input ──────────────────────────────────────────────── -->
    <EditText
        android:id="@+id/widget_add_event_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Event title"
        android:textColorHint="#66FFFFFF"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:background="@drawable/widget_input_background"
        android:padding="12dp"
        android:inputType="textCapSentences|textAutoCorrect"
        android:imeOptions="actionNext"
        android:maxLines="2"
        android:layout_marginBottom="12dp" />

    <!-- ── Date row ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Date"
            android:textColor="#99FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_add_event_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select date"
            android:textColor="#7C3AED"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:background="@drawable/widget_input_background" />

    </LinearLayout>

    <!-- ── Time row ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Time"
            android:textColor="#99FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_add_event_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select time"
            android:textColor="#7C3AED"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:background="@drawable/widget_input_background" />

    </LinearLayout>

    <!-- ── Action buttons ────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/widget_add_event_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#99FFFFFF"
            android:background="@android:color/transparent"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/widget_add_event_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7C3AED"
            android:textSize="14sp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />

    </LinearLayout>

</LinearLayout>
